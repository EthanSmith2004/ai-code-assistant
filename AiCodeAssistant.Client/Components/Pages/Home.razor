    private static string CreateCompactPath(string path, int maxLength = 58)
    {
        var trimmedPath = path.Trim();

        if (string.IsNullOrWhiteSpace(trimmedPath))
        {
            return "No root path selected.";
        }

        if (trimmedPath.Length <= maxLength)
        {
            return trimmedPath;
        }

        var parts = trimmedPath
            .Split(['\\', '/'], StringSplitOptions.RemoveEmptyEntries)
            .ToList();

        if (parts.Count >= 3)
        {
            return $"{parts[0]}\\...\\{parts[^2]}\\{parts[^1]}";
        }

        var edgeLength = Math.Max((maxLength - 3) / 2, 12);
        return $"{trimmedPath[..edgeLength]}...{trimmedPath[^edgeLength..]}";
    }

