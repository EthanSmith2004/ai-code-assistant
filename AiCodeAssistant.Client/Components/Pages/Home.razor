        {
            return;
        }

        isExplainingNode = true;
        nodeExplanation = string.Empty;
        explanationError = string.Empty;

        try
        {
            var request = new ExplainNodeRequest
            {
                SelectedNode = ToExplanationNodeContext(selectedNode),
                IncomingRelationships = GetNodeExplanationRelationships(outgoing: false),
                OutgoingRelationships = GetNodeExplanationRelationships(outgoing: true)
            };

            var response = await GraphServiceManager.ExplainNodeAsync(request);
            nodeExplanation = response.Explanation;
        }
        catch (Exception exception)
        {
            explanationError = exception.Message;
        }
        finally
        {
            isExplainingNode = false;
        }
    }

    private async Task ExplainSelectedFlowAsync()
    {
