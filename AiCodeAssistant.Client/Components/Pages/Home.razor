            .Select(node => node.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var visibleEdges = edges
            .Where(edge => visibleNodeIds.Contains(edge.SourceId) && visibleNodeIds.Contains(edge.TargetId))
            .ToList();

        if (graphMode == WorkspaceGraphMode.Mock)
        {
            return visibleEdges;
        }

        return visibleEdges.Select(edge =>
        {
            var codeEdge = GetCodeEdge(edge.Id);

            return new
            {
                edge.Id,
                edge.SourceId,
                edge.TargetId,
                Relationship = codeEdge?.Relationship ?? edge.Relationship.ToString()
