    private IEnumerable<NodeRelationship> GetOutgoingRelationships()
    {
        if (selectedNode is null)
        {
            return [];
        }

        return edges
            .Where(edge => edge.SourceId == selectedNode.Id)
            .Select(edge => CreateNodeRelationship(edge, edge.TargetId))
            .Where(relationship => relationship is not null)
            .Select(relationship => relationship!);
    }

    private IEnumerable<NodeRelationship> GetIncomingRelationships()
    {
        if (selectedNode is null)
        {
            return [];
        }

        return edges
            .Where(edge => edge.TargetId == selectedNode.Id)
            .Select(edge => CreateNodeRelationship(edge, edge.SourceId))
            .Where(relationship => relationship is not null)
            .Select(relationship => relationship!);
    }

    private NodeRelationship? CreateNodeRelationship(GraphEdge edge, string nodeId)
    {
        var node = nodes.FirstOrDefault(node => node.Id == nodeId);
        return node is null ? null : new NodeRelationship(edge, node);
    }

    private IEnumerable<FlowNodeDetail> GetSelectedFlowNodes()
    {
        if (selectedFlow is null)
        {
            return [];
        }

        return selectedFlow.NodeIds
            .Select((nodeId, index) => new FlowNodeDetail(
                index + 1,
                nodeId,
                nodes.FirstOrDefault(node => node.Id == nodeId)));
    }

    private IEnumerable<FlowRelationship> GetSelectedFlowRelationships()
    {
        if (selectedFlow is null)
        {
            return [];
        }

        var flowNodePositions = selectedFlow.NodeIds
            .Select((nodeId, index) => new { nodeId, index })
            .GroupBy(flowNode => flowNode.nodeId)
            .ToDictionary(group => group.Key, group => group.Min(flowNode => flowNode.index));

        return edges
            .Where(edge => flowNodePositions.ContainsKey(edge.SourceId) && flowNodePositions.ContainsKey(edge.TargetId))
            .OrderBy(edge => Math.Min(flowNodePositions[edge.SourceId], flowNodePositions[edge.TargetId]))
            .Select(CreateFlowRelationship)
            .Where(relationship => relationship is not null)
            .Select(relationship => relationship!);
    }

    private IEnumerable<FlowNodeDetail> GetSelectedEndpointPathNodes()
    {
        if (selectedEndpoint is null)
        {
            return [];
        }

        var relatedFlow = FindFlowForEndpoint(selectedEndpoint);

        if (relatedFlow is not null)
        {
            return GetEndpointFlowNodeIds(selectedEndpoint, relatedFlow)
                .Select((nodeId, index) => new FlowNodeDetail(
                    index + 1,
                    nodeId,
                    nodes.FirstOrDefault(node => IsSameNodeId(node.Id, nodeId))));
        }

        var focusNodeIds = GetEndpointFocusNodeIds(selectedEndpoint);
        var orderedNodeIds = new List<string> { selectedEndpoint.NodeId };
        orderedNodeIds.AddRange(
            focusNodeIds
                .Where(nodeId => !IsSameNodeId(nodeId, selectedEndpoint.NodeId))
                .OrderBy(GetEndpointPathRank)
                .ThenBy(GetNodeLabel));

        return orderedNodeIds
            .Where(focusNodeIds.Contains)
            .Select((nodeId, index) => new FlowNodeDetail(
                index + 1,
                nodeId,
                nodes.FirstOrDefault(node => IsSameNodeId(node.Id, nodeId))));
    }

    private IEnumerable<FlowRelationship> GetSelectedEndpointRelationships()
    {
        if (selectedEndpoint is null)
        {
            return [];
        }

        var focusNodeIds = GetEndpointFocusNodeIds(selectedEndpoint);
        var pathPositions = GetSelectedEndpointPathNodes()
            .Select(pathNode => new { pathNode.NodeId, Index = pathNode.Position - 1 })
            .GroupBy(pathNode => pathNode.NodeId, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.Min(pathNode => pathNode.Index), StringComparer.OrdinalIgnoreCase);

        return edges
            .Where(edge =>
                focusNodeIds.Contains(edge.SourceId) &&
                focusNodeIds.Contains(edge.TargetId) &&
                !IsStructuralRelationship(edge))
            .OrderBy(edge => Math.Min(
                pathPositions.GetValueOrDefault(edge.SourceId, int.MaxValue),
                pathPositions.GetValueOrDefault(edge.TargetId, int.MaxValue)))
            .Select(CreateFlowRelationship)
            .Where(relationship => relationship is not null)
            .Select(relationship => relationship!);
    }

    private FlowRelationship? CreateFlowRelationship(GraphEdge edge)
    {
        var sourceNode = nodes.FirstOrDefault(node => node.Id == edge.SourceId);
        var targetNode = nodes.FirstOrDefault(node => node.Id == edge.TargetId);

        return sourceNode is null || targetNode is null
            ? null
            : new FlowRelationship(edge, sourceNode, targetNode);
    }

    private IEnumerable<NodeHotspot> CalculateHotspots()
    {
        if (!nodes.Any())
        {
            return [];
        }

        var hotspotCandidates = nodes
            .Where(ShouldIncludeInHotspotScoring)
            .ToList();
        var hotspotEdges = edges
            .Where(edge => !IsStructuralRelationship(edge))
            .ToList();
        var maxPossibleDegree = Math.Max((hotspotCandidates.Count - 1) * 2, 1);

        return hotspotCandidates
            .Select(node =>
            {
                var incomingCount = hotspotEdges.Count(edge => edge.TargetId == node.Id);
                var outgoingCount = hotspotEdges.Count(edge => edge.SourceId == node.Id);
                var degree = incomingCount + outgoingCount;

                return new NodeHotspot(
                    node,
                    incomingCount,
                    outgoingCount,
                    degree,
                    degree / (double)maxPossibleDegree);
            })
            .Where(hotspot => hotspot.Degree > 0)
            .OrderByDescending(hotspot => hotspot.Degree)
            .ThenByDescending(hotspot => hotspot.OutgoingCount)
            .ThenBy(hotspot => hotspot.Node.Label);
    }

    private NodeHotspot? GetHotspot(string nodeId)
    {
        return hotspots.FirstOrDefault(hotspot => hotspot.Node.Id == nodeId);
    }

    private CodeFlow? FindFlowForEndpoint(EndpointInfo endpoint)
    {
        return flows.FirstOrDefault(flow =>
            flow.NodeIds.Any(nodeId => IsSameNodeId(nodeId, endpoint.NodeId)));
    }

    private static IEnumerable<string> GetEndpointFlowNodeIds(EndpointInfo selectedEndpoint, CodeFlow relatedFlow)
    {
        var endpointIndex = relatedFlow.NodeIds.FindIndex(nodeId => IsSameNodeId(nodeId, selectedEndpoint.NodeId));

        return endpointIndex < 0
            ? relatedFlow.NodeIds
            : relatedFlow.NodeIds.Skip(endpointIndex);
    }

    private int GetEndpointPathRank(string nodeId)
    {
        var node = nodes.FirstOrDefault(node => IsSameNodeId(node.Id, nodeId));
        var kind = node is null ? string.Empty : GetNodeKindLabel(node);

        return kind switch
        {
            "Controller" => 10,
            "Service" => 20,
            "Analyzer" => 30,
            "Scanner" => 35,
            "Detector" => 35,
            "Simplifier" => 35,
            "Repository" => 40,
            _ => 90
        };
    }

    private string GetNodeLabel(string nodeId)
    {
        return nodes.FirstOrDefault(node => IsSameNodeId(node.Id, nodeId))?.Label ?? nodeId;
    }

    private static bool IsSameNodeId(string left, string right)
    {
        return string.Equals(left, right, StringComparison.OrdinalIgnoreCase);
    }

    private CodeNode? GetSelectedCodeNode()
    {
        return selectedNode is null ? null : GetCodeNode(selectedNode.Id);
    }

    private CodeNode? GetCodeNode(string nodeId)
    {
        return scannedNodesById.TryGetValue(nodeId, out var codeNode)
            ? codeNode
            : null;
    }

    private CodeEdge? GetCodeEdge(string edgeId)
    {
        return scannedEdgesById.TryGetValue(edgeId, out var codeEdge)
            ? codeEdge
            : null;
    }

    private IEnumerable<ScannedRelationship> GetScannedRelationships(string nodeId, bool outgoing)
    {
        if (graphMode != WorkspaceGraphMode.Scanned)
        {
            return [];
        }

        return scannedEdgesById.Values
            .Where(edge => outgoing ? edge.SourceId == nodeId : edge.TargetId == nodeId)
            .Select(edge =>
            {
                var peerNodeId = outgoing ? edge.TargetId : edge.SourceId;
                var peerNode = GetCodeNode(peerNodeId);

                return peerNode is null
                    ? null
                    : new ScannedRelationship(
                        edge.Relationship,
                        peerNode,
                        outgoing ? "To" : "From",
                        IsStructuralRelationship(edge.Relationship));
            })
            .Where(relationship => relationship is not null)
            .Select(relationship => relationship!);
    }

    private List<NodeRelationshipContext> GetNodeExplanationRelationships(bool outgoing)
    {
        if (graphMode == WorkspaceGraphMode.Scanned && selectedNode is not null)
        {
            return GetScannedRelationships(selectedNode.Id, outgoing)
                .Where(relationship => !relationship.IsStructural)
                .Select(relationship => new NodeRelationshipContext
                {
                    Relationship = relationship.Relationship,
                    Node = ToCodeNodeContext(relationship.Node)
                })
                .ToList();
        }

        var relationships = outgoing ? GetOutgoingRelationships() : GetIncomingRelationships();
        return relationships
            .Select(relationship => ToRelationshipContext(relationship))
            .ToList();
    }

    private bool ShouldIncludeInHotspotScoring(GraphNode node)
    {
        if (graphMode != WorkspaceGraphMode.Scanned)
        {
            return true;
        }

        var codeNode = GetCodeNode(node.Id);
        return codeNode is not null && !IsContainerNode(codeNode);
    }

    private bool CanExplainSelectedNode()
    {
        if (selectedNode is null || graphMode != WorkspaceGraphMode.Scanned)
        {
            return selectedNode is not null;
        }

        var codeNode = GetCodeNode(selectedNode.Id);
        return codeNode is not null && !IsContainerNode(codeNode);
    }

    private bool IsStructuralRelationship(GraphEdge edge)
    {
        return graphMode == WorkspaceGraphMode.Scanned &&
               GetCodeEdge(edge.Id) is { } codeEdge &&
               IsStructuralRelationship(codeEdge.Relationship);
    }

    private static bool IsStructuralRelationship(string relationship)
    {
        return relationship is "Contains" or "ContainsConfig" or "ContainsProjectFile" or "HasEntryPoint";
    }

    private static bool IsContainerNode(CodeNode node)
    {
        return node.Kind is "Project" or "Folder";
    }

    private static bool IsLowValueGraphNode(CodeNode node)
    {
        return node.Kind is "Project" or "Folder" or "ProjectFile" or "Config" or "File";
    }

    private static GraphNode ToGraphNode(CodeNode node)
    {
        return new GraphNode
        {
            Id = node.Id,
            Label = node.Label,
            Type = ToNodeType(node.Kind),
            Layer = ToLayerType(node.Layer),
            Description = CreateScannedNodeDescription(node)
        };
    }

    private static GraphEdge ToGraphEdge(CodeEdge edge)
    {
        return new GraphEdge
        {
            Id = edge.Id,
            SourceId = edge.SourceId,
            TargetId = edge.TargetId,
            Relationship = ToRelationshipType(edge.Relationship)
        };
    }

    private static NodeType ToNodeType(string kind)
    {
        return kind switch
        {
            "Route" => NodeType.Page,
            "Endpoint" => NodeType.Endpoint,
            "Component" => NodeType.Component,
            "Controller" => NodeType.Controller,
            "Service" => NodeType.Service,
            "Repository" => NodeType.Repository,
            "Entity" => NodeType.Database,
            "Manager" => NodeType.Component,
            "RestClient" => NodeType.Component,
            "Scanner" => NodeType.Service,
            "Detector" => NodeType.Service,
            "Analyzer" => NodeType.Service,
            "Simplifier" => NodeType.Service,
            _ => NodeType.Component
        };
    }

    private static LayerType ToLayerType(string layer)
    {
        return layer switch
        {
            "Frontend" => LayerType.Frontend,
            "Api" => LayerType.Api,
            "Application" => LayerType.Application,
            "Data" => LayerType.Data,
            _ => LayerType.Application
        };
    }

    private static RelationshipType ToRelationshipType(string relationship)
    {
        if (Enum.TryParse<RelationshipType>(relationship, ignoreCase: true, out var parsedRelationship))
        {
            return parsedRelationship;
        }

        return relationship switch
        {
            "HasEntryPoint" => RelationshipType.MapsTo,
            _ => RelationshipType.Uses
        };
    }

    private static string CreateScannedNodeDescription(CodeNode node)
    {
        var sourcePath = string.IsNullOrWhiteSpace(node.SourcePath)
            ? "No source path available."
            : $"Source: {node.SourcePath}";

        return $"{node.Kind} in the {node.Layer} layer. {node.Description} {sourcePath}";
    }

    private NodeContext ToExplanationNodeContext(GraphNode node)
    {
        var codeNode = GetCodeNode(node.Id);
        return codeNode is null ? ToNodeContext(node) : ToCodeNodeContext(codeNode);
    }

    private static NodeContext ToCodeNodeContext(CodeNode node)
    {
        return new NodeContext
        {
            Id = node.Id,
            Label = node.Label,
            Type = node.Kind,
            Layer = node.Layer,
            Description = CreateScannedNodeDescription(node)
        };
    }

    private static NodeContext ToNodeContext(GraphNode node)
    {
        return new NodeContext
        {
            Id = node.Id,
            Label = node.Label,
            Type = node.Type.ToString(),
            Layer = node.Layer.ToString(),
            Description = node.Description
        };
    }

    private static NodeRelationshipContext ToRelationshipContext(NodeRelationship relationship)
    {
        return new NodeRelationshipContext
        {
            Relationship = relationship.Edge.Relationship.ToString(),
            Node = ToNodeContext(relationship.Node)
        };
    }

    private FlowRelationshipContext ToFlowRelationshipContext(FlowRelationship relationship)
    {
        return new FlowRelationshipContext
        {
            Relationship = relationship.Edge.Relationship.ToString(),
            SourceNode = ToExplanationNodeContext(relationship.SourceNode),
            TargetNode = ToExplanationNodeContext(relationship.TargetNode)
        };
    }

    private void ClearNodeExplanation()
    {
        nodeExplanation = string.Empty;
        explanationError = string.Empty;
        isExplainingNode = false;
    }

    private void ClearFlowExplanation()
    {
        flowExplanation = string.Empty;
        flowExplanationError = string.Empty;
        isExplainingFlow = false;
    }

    private void ClearEndpointExplanation()
    {
        endpointExplanation = string.Empty;
        endpointExplanationError = string.Empty;
        isExplainingEndpoint = false;
    }

    private void ClearSaveStatus()
    {
        saveStatusMessage = string.Empty;
        saveError = string.Empty;
        isSavingAnalysis = false;
    }

    public void Dispose()
    {
        dotNetReference?.Dispose();
    }

    private sealed record NodeRelationship(GraphEdge Edge, GraphNode Node);

    private sealed record FlowNodeDetail(int Position, string NodeId, GraphNode? Node);

    private sealed record FlowRelationship(GraphEdge Edge, GraphNode SourceNode, GraphNode TargetNode);

    private sealed record ScannedRelationship(string Relationship, CodeNode Node, string Direction, bool IsStructural);

    private sealed record NodeHotspot(
        GraphNode Node,
        int IncomingCount,
        int OutgoingCount,
        int Degree,
        double Centrality);

    private enum WorkspaceGraphMode
    {
        Mock,
        Scanned
    }

    private enum GraphViewMode
    {
        Full,
        FlowFocus,
        EndpointFocus
    }
}
