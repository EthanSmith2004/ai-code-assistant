@page "/graph"
@rendermode InteractiveServer

@using AiCodeAssistant.Domain.Analysis
@using AiCodeAssistant.Domain.Contracts.Ai
@using AiCodeAssistant.Domain.Contracts.Projects
@using AiCodeAssistant.Domain.Entities
@using AiCodeAssistant.Domain.Graph
@implements IDisposable
@inject AiCodeAssistant.Client.Services.UserPreferencesService UserPreferencesService
@inject AiCodeAssistant.Client.Services.Managers.GraphServiceManager GraphServiceManager
@inject IJSRuntime JS

<div class="workspace">
    <aside class="workspace-panel explorer-panel">
        <div class="panel-header">
            <div>
                <span class="panel-kicker">Workspace</span>
                <h2>Explorer</h2>
            </div>
            <button class="load-button" @onclick="LoadData">@GetLoadButtonText()</button>
        </div>

        <div class="panel-body">
            <section class="source-section">
                <h3>Graph Source</h3>
                <div class="mode-selector" role="group" aria-label="Graph source">
                    <button class="mode-button @(graphMode == WorkspaceGraphMode.Mock ? "selected" : null)"
                            @onclick="() => SetGraphMode(WorkspaceGraphMode.Mock)">
                        Mock graph
                    </button>
                    <button class="mode-button @(graphMode == WorkspaceGraphMode.Scanned ? "selected" : null)"
                            @onclick="() => SetGraphMode(WorkspaceGraphMode.Scanned)">
                        Scanned project
                    </button>
                </div>

                @if (graphMode == WorkspaceGraphMode.Scanned)
                {
                    <label class="scan-path-field">
                        <span>Root path</span>
                        <input @bind="scanRootPath" @bind:event="oninput" placeholder="d:\Fork\ai-code-assistant" />
                        <small class="path-preview" title="@scanRootPath">@GetReadableRootPath()</small>
                    </label>
                }

                @if (!string.IsNullOrWhiteSpace(sourceHintMessage))
                {
                    <p class="source-hint">@sourceHintMessage</p>
                }

                @if (!string.IsNullOrWhiteSpace(loadError))
                {
                    <p class="load-error">@loadError</p>
                }
            </section>

            @if (nodes.Count > 0)
            {
                <section class="flow-section">
                    <h3>Flows</h3>
                    @if (flows.Any())
                    {
                        <div class="flow-list">
                            @foreach (var flow in flows)
                            {
                                <button class="flow-button @(selectedFlow?.Id == flow.Id ? "selected" : null)"
                                        @onclick="() => SelectFlowAsync(flow)">
                                    <span>@flow.Name</span>
                                    <small>@flow.NodeIds.Count nodes</small>
                                </button>
                            }
                        </div>

                        @if (selectedFlow is not null)
                        {
                            <p class="flow-description">@selectedFlow.Description</p>
                        }
                    }
                    else
                    {
                        <p class="empty-state">@GetNoFlowsMessage()</p>
                    }
                </section>

                <section class="hotspot-section">
                    <div class="section-title-row">
                        <h3>Hotspots</h3>
                        <button class="secondary-action-button" @onclick="HighlightHotspotsAsync" disabled="@(!hotspots.Any())">
                            Highlight
                        </button>
                    </div>
                    <p class="analysis-note">Degree = incoming plus outgoing relationships.</p>

                    @if (hotspots.Any())
                    {
                        <ol class="hotspot-list">
                            @foreach (var hotspot in hotspots.Take(5))
                            {
                                <li>
                                    <div>
                                        <span class="hotspot-name">@hotspot.Node.Label</span>
                                        <small>@GetNodeSummary(hotspot.Node)</small>
                                    </div>
                                    <div class="hotspot-metrics">
                                        <span>@hotspot.Degree</span>
                                        <small>@hotspot.IncomingCount in / @hotspot.OutgoingCount out</small>
                                    </div>
                                </li>
                            }
                        </ol>
                    }
                    else
                    {
                        <p class="empty-state">No connected nodes found yet.</p>
                    }
                </section>

                <section class="endpoint-section">
                    <h3>Endpoints</h3>
                    @if (endpoints.Any())
                    {
                        <div class="endpoint-groups">
                            @foreach (var group in endpoints.GroupBy(endpoint => endpoint.HttpMethod))
                            {
                                <section class="endpoint-group">
                                    <h4>@group.Key</h4>
                                    <div class="endpoint-list">
                                        @foreach (var endpoint in group)
                                        {
                                            <button class="endpoint-button @(selectedEndpoint?.NodeId == endpoint.NodeId ? "selected" : null)"
                                                    @onclick="() => SelectEndpointAsync(endpoint)">
                                                <span>@endpoint.Route</span>
                                                <small>@endpoint.RequestType -> @endpoint.ResponseType</small>
                                            </button>
                                        }
                                    </div>
                                </section>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-state">@GetNoEndpointsMessage()</p>
                    }
                </section>

                <div class="node-groups">
                    <h3>Nodes by Layer</h3>

                    @foreach (var group in nodes.GroupBy(GetNodeGroupLabel))
                    {
                        <section class="node-group">
                            <h4>@group.Key</h4>
                            <ul>
                                @foreach (var node in group)
                                {
                                    <li>@node.Label (@GetNodeKindLabel(node))</li>
                                }
                            </ul>
                        </section>
                    }
                </div>
            }
            else
            {
                <p class="empty-state">Load the graph to browse nodes by layer.</p>
            }
        </div>
    </aside>

    <main class="graph-panel">
        <header class="workspace-heading">
            <div>
                <span class="panel-kicker">Graph Area</span>
                <h1>Graph Explorer</h1>
                <p>Explore structure, endpoints, flows, and hotspots</p>
            </div>
            <div class="graph-toolbar" aria-label="Graph controls">
                <span class="graph-view-chip">@GetGraphViewLabel()</span>
                <select class="layout-select" value="@selectedLayout" @onchange="ChangeLayoutAsync" aria-label="Graph layout">
                    <option value="breadthfirst">Layered</option>
                    <option value="cose">Organic</option>
                </select>
                <button class="save-analysis-button" @onclick="SaveCurrentAnalysisAsync" disabled="@(!CanSaveAnalysis)">
                    @(isSavingAnalysis ? "Saving..." : "Save analysis")
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(saveStatusMessage) || !string.IsNullOrWhiteSpace(saveError))
        {
            <div class="save-status-bar @(string.IsNullOrWhiteSpace(saveError) ? "success" : "error")" role="status">
                <span>@(string.IsNullOrWhiteSpace(saveError) ? saveStatusMessage : saveError)</span>
                @if (string.IsNullOrWhiteSpace(saveError))
                {
                    <a href="/history">View history</a>
                }
            </div>
        }

        <section class="workflow-strip" aria-label="Graph Explorer workflow">
            <div class="workflow-step @GetWorkflowStepClass(1)">
                <span>1</span>
                <strong>Scan</strong>
            </div>
            <div class="workflow-step @GetWorkflowStepClass(2)">
                <span>2</span>
                <strong>Select flow</strong>
            </div>
            <div class="workflow-step @GetWorkflowStepClass(3)">
                <span>3</span>
                <strong>Explore</strong>
            </div>
            <div class="workflow-step @GetWorkflowStepClass(4)">
                <span>4</span>
                <strong>Save</strong>
            </div>
        </section>

        <section class="graph-viewport">
            <div class="graph-stage">
                <div class="graph-stage-body">
                    <div id="graph" class="graph-canvas"></div>
                    <div class="graph-floating-controls" role="toolbar" aria-label="Graph navigation controls">
                        <button class="graph-icon-button" @onclick="ZoomOutAsync" disabled="@(!nodes.Any())" aria-label="Zoom out" title="Zoom out">
                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <circle cx="10.5" cy="10.5" r="5.5"></circle>
                                <path d="M15 15l4.5 4.5"></path>
                                <path d="M8 10.5h5"></path>
                            </svg>
                        </button>
                        <button class="graph-icon-button" @onclick="ZoomInAsync" disabled="@(!nodes.Any())" aria-label="Zoom in" title="Zoom in">
                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <circle cx="10.5" cy="10.5" r="5.5"></circle>
                                <path d="M15 15l4.5 4.5"></path>
                                <path d="M10.5 8v5"></path>
                                <path d="M8 10.5h5"></path>
                            </svg>
                        </button>
                        <button class="graph-icon-button" @onclick="FitGraphAsync" disabled="@(!nodes.Any())" aria-label="Fit graph" title="Fit graph">
                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M5 9V5h4"></path>
                                <path d="M15 5h4v4"></path>
                                <path d="M19 15v4h-4"></path>
                                <path d="M9 19H5v-4"></path>
                                <path d="M8 12h8"></path>
                            </svg>
                        </button>
                        <button class="graph-icon-button" @onclick="ResetGraphViewAsync" disabled="@(!nodes.Any())" aria-label="Reset layout" title="Reset layout">
                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M6 9a7 7 0 1 1 1.6 8.8"></path>
                                <path d="M6 5v4h4"></path>
                            </svg>
                        </button>
                        <button class="graph-icon-button" @onclick="ShowFullGraphAsync" disabled="@(!nodes.Any() || graphViewMode == GraphViewMode.Full)" aria-label="Show full graph" title="Show full graph">
                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <circle cx="6" cy="7" r="2"></circle>
                                <circle cx="18" cy="7" r="2"></circle>
                                <circle cx="12" cy="17" r="2"></circle>
                                <path d="M8 8l3 7"></path>
                                <path d="M16 8l-3 7"></path>
                                <path d="M8 7h8"></path>
                            </svg>
                        </button>
                        <button class="graph-icon-button" @onclick="ToggleFullscreenAsync" disabled="@(!nodes.Any())" aria-label="Toggle fullscreen" title="Toggle fullscreen">
                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M8 4H4v4"></path>
                                <path d="M16 4h4v4"></path>
                                <path d="M20 16v4h-4"></path>
                                <path d="M4 16v4h4"></path>
                            </svg>
                        </button>
                    </div>
                    <div id="graph-vertical-pan" class="graph-pan-bar vertical" role="slider" aria-label="Vertical graph position" aria-orientation="vertical" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0">
                        <span class="graph-pan-track">
                            <span class="graph-pan-thumb"></span>
                        </span>
                    </div>
                </div>
                <div id="graph-horizontal-pan" class="graph-pan-bar horizontal" role="slider" aria-label="Horizontal graph position" aria-orientation="horizontal" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0">
                    <span class="graph-pan-track">
                        <span class="graph-pan-thumb"></span>
                    </span>
                </div>
            </div>
        </section>
    </main>

    <aside class="workspace-panel details-panel">
        <div class="panel-header">
            <div>
                <span class="panel-kicker">Selection</span>
                <h2>Details</h2>
            </div>
            @if (selectedNode is not null)
            {
                <span class="selection-badge">Selected node</span>
            }
            else if (selectedFlow is not null)
            {
                <span class="selection-badge">Focused flow</span>
            }
            else if (selectedEndpoint is not null)
            {
                <span class="selection-badge">Endpoint path</span>
            }
        </div>

        <div class="panel-body">
            @if (selectedNode is not null)
            {
                var scannedNode = GetSelectedCodeNode();
                var selectedHotspot = GetHotspot(selectedNode.Id);

                @if (scannedNode is not null)
                {
                    var scannedOutgoing = GetScannedRelationships(selectedNode.Id, outgoing: true).ToList();
                    var scannedIncoming = GetScannedRelationships(selectedNode.Id, outgoing: false).ToList();
                    var behavioralOutgoing = scannedOutgoing.Where(relationship => !relationship.IsStructural).ToList();
                    var behavioralIncoming = scannedIncoming.Where(relationship => !relationship.IsStructural).ToList();
                    var structuralRelationships = scannedOutgoing
                        .Concat(scannedIncoming)
                        .Where(relationship => relationship.IsStructural)
                        .ToList();

                    <dl class="detail-list">
                        <div>
                            <dt>Label</dt>
                            <dd>@scannedNode.Label</dd>
                        </div>
                        <div>
                            <dt>Kind</dt>
                            <dd>@scannedNode.Kind</dd>
                        </div>
                        <div>
                            <dt>Layer</dt>
                            <dd>@scannedNode.Layer</dd>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(scannedNode.SourcePath))
                        {
                            <div>
                                <dt>Source</dt>
                                <dd>@scannedNode.SourcePath</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(scannedNode.Language))
                        {
                            <div>
                                <dt>Language</dt>
                                <dd>@scannedNode.Language</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(scannedNode.Framework))
                        {
                            <div>
                                <dt>Framework</dt>
                                <dd>@scannedNode.Framework</dd>
                            </div>
                        }
                        <div>
                            <dt>Description</dt>
                            <dd>@scannedNode.Description</dd>
                        </div>
                        @if (selectedHotspot is not null)
                        {
                            <div>
                                <dt>Hotspot Score</dt>
                                <dd>Degree @selectedHotspot.Degree (@selectedHotspot.IncomingCount incoming / @selectedHotspot.OutgoingCount outgoing)</dd>
                            </div>
                            <div>
                                <dt>Centrality</dt>
                                <dd>@selectedHotspot.Centrality.ToString("P0")</dd>
                            </div>
                        }
                    </dl>

                    @if (IsContainerNode(scannedNode))
                    {
                        <p class="semantic-note">This is a structural container, so hotspot scoring, AI explanation, and relationship lists are omitted.</p>
                    }
                    else if (CanExplainSelectedNode())
                    {
                        <section class="ai-explanation-section">
                            <button class="ai-explanation-button" @onclick="ExplainSelectedNodeAsync" disabled="@isExplainingNode">
                                @(isExplainingNode ? "Explaining..." : "Explain this node")
                            </button>

                            @if (!string.IsNullOrWhiteSpace(explanationError))
                            {
                                <p class="ai-explanation-error">@explanationError</p>
                            }

                            @if (!string.IsNullOrWhiteSpace(nodeExplanation))
                            {
                                <p class="ai-explanation-result">@nodeExplanation</p>
                            }
                        </section>
                    }
                    else
                    {
                        <p class="semantic-note">AI explanations are skipped for project and folder container nodes.</p>
                    }

                    @if (!IsContainerNode(scannedNode))
                    {
                        <section class="relationship-section">
                            <h3>Behavioral Relationships</h3>
                            @if (behavioralOutgoing.Any() || behavioralIncoming.Any())
                            {
                                <ul class="relationship-list">
                                    @foreach (var relationship in behavioralOutgoing)
                                    {
                                        <li>
                                            <span class="relationship-type">@relationship.Relationship</span>
                                            <span class="relationship-peer">To @relationship.Node.Label</span>
                                            <small>@relationship.Node.Kind - @relationship.Node.Layer</small>
                                        </li>
                                    }
                                    @foreach (var relationship in behavioralIncoming)
                                    {
                                        <li>
                                            <span class="relationship-type">@relationship.Relationship</span>
                                            <span class="relationship-peer">From @relationship.Node.Label</span>
                                            <small>@relationship.Node.Kind - @relationship.Node.Layer</small>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="empty-state">No inferred runtime relationships for this node yet.</p>
                            }
                        </section>

                        @if (graphViewMode == GraphViewMode.Full)
                        {
                            <section class="relationship-section">
                                <h3>Structural Context</h3>
                                @if (structuralRelationships.Any())
                                {
                                    <ul class="relationship-list structural-list">
                                        @foreach (var relationship in structuralRelationships)
                                        {
                                            <li>
                                                <span class="relationship-type">@relationship.Relationship</span>
                                                <span class="relationship-peer">@relationship.Direction @relationship.Node.Label</span>
                                                <small>@relationship.Node.Kind - @relationship.Node.Layer</small>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="empty-state">No structural context is available for this node.</p>
                                }
                            </section>
                        }
                        else
                        {
                            <p class="semantic-note">Focus mode hides broad structural context so this panel stays centered on the active path.</p>
                        }
                    }
                }
                else
                {
                    var outgoingRelationships = GetOutgoingRelationships().ToList();
                    var incomingRelationships = GetIncomingRelationships().ToList();

                    <dl class="detail-list">
                        <div>
                            <dt>Label</dt>
                            <dd>@selectedNode.Label</dd>
                        </div>
                        <div>
                            <dt>Id</dt>
                            <dd>@selectedNode.Id</dd>
                        </div>
                        <div>
                            <dt>Layer</dt>
                            <dd>@selectedNode.Layer</dd>
                        </div>
                        <div>
                            <dt>Type</dt>
                            <dd>@selectedNode.Type</dd>
                        </div>
                        <div>
                            <dt>Description</dt>
                            <dd>@selectedNode.Description</dd>
                        </div>
                        @if (selectedHotspot is not null)
                        {
                            <div>
                                <dt>Hotspot Score</dt>
                                <dd>Degree @selectedHotspot.Degree (@selectedHotspot.IncomingCount incoming / @selectedHotspot.OutgoingCount outgoing)</dd>
                            </div>
                            <div>
                                <dt>Centrality</dt>
                                <dd>@selectedHotspot.Centrality.ToString("P0")</dd>
                            </div>
                        }
                    </dl>

                    <section class="ai-explanation-section">
                        <button class="ai-explanation-button" @onclick="ExplainSelectedNodeAsync" disabled="@isExplainingNode">
                            @(isExplainingNode ? "Explaining..." : "Explain this node")
                        </button>

                        @if (!string.IsNullOrWhiteSpace(explanationError))
                        {
                            <p class="ai-explanation-error">@explanationError</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(nodeExplanation))
                        {
                            <p class="ai-explanation-result">@nodeExplanation</p>
                        }
                    </section>

                    <section class="relationship-section">
                        <h3>Outgoing</h3>
                        @if (outgoingRelationships.Any())
                        {
                            <ul class="relationship-list">
                                @foreach (var relationship in outgoingRelationships)
                                {
                                    <li>
                                        <span class="relationship-type">@relationship.Edge.Relationship</span>
                                        <span class="relationship-peer">To @relationship.Node.Label</span>
                                        <small>@relationship.Node.Type - @relationship.Node.Layer</small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="empty-state">No outgoing relationships.</p>
                        }
                    </section>

                    <section class="relationship-section">
                        <h3>Incoming</h3>
                        @if (incomingRelationships.Any())
                        {
                            <ul class="relationship-list">
                                @foreach (var relationship in incomingRelationships)
                                {
                                    <li>
                                        <span class="relationship-type">@relationship.Edge.Relationship</span>
                                        <span class="relationship-peer">From @relationship.Node.Label</span>
                                        <small>@relationship.Node.Type - @relationship.Node.Layer</small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="empty-state">No incoming relationships.</p>
                        }
                    </section>
                }
            }
            else if (selectedFlow is not null)
            {
                var flowNodes = GetSelectedFlowNodes().ToList();
                var flowRelationships = GetSelectedFlowRelationships().ToList();

                <dl class="detail-list">
                    <div>
                        <dt>Flow</dt>
                        <dd>@selectedFlow.Name</dd>
                    </div>
                    <div>
                        <dt>Description</dt>
                        <dd>@selectedFlow.Description</dd>
                    </div>
                </dl>

                <section class="ai-explanation-section">
                    <button class="ai-explanation-button" @onclick="ExplainSelectedFlowAsync" disabled="@isExplainingFlow">
                        @(isExplainingFlow ? "Explaining..." : "Explain this flow")
                    </button>

                    @if (!string.IsNullOrWhiteSpace(flowExplanationError))
                    {
                        <p class="ai-explanation-error">@flowExplanationError</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(flowExplanation))
                    {
                        <p class="ai-explanation-result">@flowExplanation</p>
                    }
                </section>

                <section class="flow-detail-section">
                    <h3>Ordered Nodes</h3>
                    @if (flowNodes.Any())
                    {
                        <ol class="flow-node-list">
                            @foreach (var flowNode in flowNodes)
                            {
                                <li>
                                    <span class="flow-node-position">@flowNode.Position</span>
                                    <div>
                                        @if (flowNode.Node is not null)
                                        {
                                            <span class="flow-node-name">@flowNode.Node.Label</span>
                                            <small>@flowNode.Node.Type - @flowNode.Node.Layer</small>
                                        }
                                        else
                                        {
                                            <span class="flow-node-name">@flowNode.NodeId</span>
                                            <small>Node data unavailable</small>
                                        }
                                    </div>
                                </li>
                            }
                        </ol>
                    }
                    else
                    {
                        <p class="empty-state">No nodes are listed for this flow.</p>
                    }
                </section>

                <section class="relationship-section">
                    <h3>Flow Relationships</h3>
                    @if (flowRelationships.Any())
                    {
                        <ul class="relationship-list">
                            @foreach (var relationship in flowRelationships)
                            {
                                <li>
                                    <span class="relationship-type">@relationship.Edge.Relationship</span>
                                    <span class="relationship-peer">@relationship.SourceNode.Label -> @relationship.TargetNode.Label</span>
                                    <small>@relationship.SourceNode.Layer to @relationship.TargetNode.Layer</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="empty-state">No direct relationships are mapped between these nodes.</p>
                    }
                </section>
            }
            else if (selectedEndpoint is not null)
            {
                var endpointPathNodes = GetSelectedEndpointPathNodes().ToList();
                var endpointRelationships = GetSelectedEndpointRelationships().ToList();

                <dl class="detail-list">
                    <div>
                        <dt>Method</dt>
                        <dd>@selectedEndpoint.HttpMethod</dd>
                    </div>
                    <div>
                        <dt>Route</dt>
                        <dd>@selectedEndpoint.Route</dd>
                    </div>
                    <div>
                        <dt>Request Type</dt>
                        <dd>@selectedEndpoint.RequestType</dd>
                    </div>
                    <div>
                        <dt>Response Type</dt>
                        <dd>@selectedEndpoint.ResponseType</dd>
                    </div>
                    <div>
                        <dt>Graph View</dt>
                        <dd>@GetGraphViewLabel()</dd>
                    </div>
                </dl>

                <section class="ai-explanation-section">
                    <button class="ai-explanation-button" @onclick="ExplainSelectedEndpointAsync" disabled="@isExplainingEndpoint">
                        @(isExplainingEndpoint ? "Explaining..." : "Explain this endpoint")
                    </button>

                    @if (!string.IsNullOrWhiteSpace(endpointExplanationError))
                    {
                        <p class="ai-explanation-error">@endpointExplanationError</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(endpointExplanation))
                    {
                        <p class="ai-explanation-result">@endpointExplanation</p>
                    }
                </section>

                <section class="flow-detail-section">
                    <h3>Focused Path</h3>
                    @if (endpointPathNodes.Any())
                    {
                        <ol class="flow-node-list">
                            @foreach (var pathNode in endpointPathNodes)
                            {
                                <li>
                                    <span class="flow-node-position">@pathNode.Position</span>
                                    <div>
                                        @if (pathNode.Node is not null)
                                        {
                                            <span class="flow-node-name">@pathNode.Node.Label</span>
                                            <small>@GetNodeKindLabel(pathNode.Node) - @GetNodeGroupLabel(pathNode.Node)</small>
                                        }
                                        else
                                        {
                                            <span class="flow-node-name">@pathNode.NodeId</span>
                                            <small>Node data unavailable</small>
                                        }
                                    </div>
                                </li>
                            }
                        </ol>
                    }
                    else
                    {
                        <p class="empty-state">No focused path is available for this endpoint yet.</p>
                    }
                </section>

                <section class="relationship-section">
                    <h3>Endpoint Relationships</h3>
                    @if (endpointRelationships.Any())
                    {
                        <ul class="relationship-list">
                            @foreach (var relationship in endpointRelationships)
                            {
                                <li>
                                    <span class="relationship-type">@relationship.Edge.Relationship</span>
                                    <span class="relationship-peer">@relationship.SourceNode.Label -> @relationship.TargetNode.Label</span>
                                    <small>@GetNodeKindLabel(relationship.SourceNode) to @GetNodeKindLabel(relationship.TargetNode)</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="empty-state">No direct endpoint relationships are mapped yet.</p>
                    }
                </section>
            }
            else
            {
                <p class="empty-state">Select a node, flow, or endpoint to inspect it here.</p>
            }
        </div>
    </aside>
</div>

