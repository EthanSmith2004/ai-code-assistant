        {
            return;
        }

        isExplainingFlow = true;
        flowExplanation = string.Empty;
        flowExplanationError = string.Empty;

        try
        {
            var request = new ExplainFlowRequest
            {
                FlowId = selectedFlow.Id,
                FlowName = selectedFlow.Name,
                Description = selectedFlow.Description,
                OrderedNodes = GetSelectedFlowNodes()
                    .Where(flowNode => flowNode.Node is not null)
                    .Select(flowNode => new FlowNodeContext
                    {
                        Position = flowNode.Position,
                        Node = ToExplanationNodeContext(flowNode.Node!)
                    })
                    .ToList(),
                Relationships = GetSelectedFlowRelationships()
                    .Select(ToFlowRelationshipContext)
                    .ToList()
            };

            var response = await GraphServiceManager.ExplainFlowAsync(request);
            flowExplanation = response.Explanation;
