    private IEnumerable<GraphNode> GetVisibleGraphNodes()
    {
        var visibleNodeIds = GetCurrentViewNodeIds();
        var visibleNodes = visibleNodeIds is null
            ? nodes
            : nodes.Where(node => visibleNodeIds.Contains(node.Id));

        return visibleNodes.Where(ShouldRenderGraphNode);
    }

    private bool ShouldRenderGraphNode(GraphNode node)
    {
        if (graphMode != WorkspaceGraphMode.Scanned || graphViewMode != GraphViewMode.Full)
        {
            return true;
        }

        var codeNode = GetCodeNode(node.Id);
        return codeNode is null || !IsLowValueGraphNode(codeNode);
    }

    private HashSet<string>? GetCurrentViewNodeIds()
    {
        return graphViewMode switch
        {
            GraphViewMode.FlowFocus when selectedFlow is not null => selectedFlow.NodeIds.ToHashSet(StringComparer.OrdinalIgnoreCase),
            GraphViewMode.EndpointFocus when selectedEndpoint is not null => GetEndpointFocusNodeIds(selectedEndpoint),
            _ => null
        };
    }

    private HashSet<string> GetEndpointFocusNodeIds(EndpointInfo endpoint)
    {
        var relatedFlow = FindFlowForEndpoint(endpoint);

        if (relatedFlow is not null)
        {
            return GetEndpointFlowNodeIds(endpoint, relatedFlow)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
        }

        var nodeIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            endpoint.NodeId
        };
        var queue = new Queue<(string NodeId, int Depth)>();
        queue.Enqueue((endpoint.NodeId, 0));

        while (queue.Count > 0)
        {
            var (nodeId, depth) = queue.Dequeue();

            if (depth >= 4)
            {
                continue;
            }

            foreach (var edge in edges.Where(edge =>
                         IsSameNodeId(edge.SourceId, nodeId) &&
                         !IsStructuralRelationship(edge)))
            {
                if (nodeIds.Add(edge.TargetId))
                {
                    queue.Enqueue((edge.TargetId, depth + 1));
                }
            }
        }

        foreach (var edge in edges.Where(edge =>
                     IsSameNodeId(edge.TargetId, endpoint.NodeId) &&
                     !IsStructuralRelationship(edge)))
        {
            nodeIds.Add(edge.SourceId);
        }

        return nodeIds;
    }

