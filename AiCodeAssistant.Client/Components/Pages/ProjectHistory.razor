@page "/history"
@rendermode InteractiveServer

@using AiCodeAssistant.Domain.Contracts.Projects
@inject AiCodeAssistant.Client.Services.Managers.GraphServiceManager GraphServiceManager

<section class="history-page">
    <header class="page-heading">
        <div>
            <span class="page-kicker">Project History</span>
            <h1>Saved Analyses</h1>
            <p>Review projects and analysis snapshots saved from Graph Explorer.</p>
        </div>
        <a class="primary-link" href="/graph">Analyze another project</a>
    </header>

    @if (isLoading)
    {
        <p class="page-state">Loading project history...</p>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <p class="page-state error">@loadError</p>
    }
    else if (!projects.Any())
    {
        <div class="page-state empty-panel">
            <strong>No saved projects yet.</strong>
            <span>Scan a project in Graph Explorer, then save the analysis snapshot here.</span>
            <a class="primary-link inline" href="/graph">Analyze New Project</a>
        </div>
    }
    else
    {
        <div class="history-layout">
            <section class="project-list" aria-label="Saved projects">
                @foreach (var project in projects)
                {
                    <button class="project-row @(selectedProjectId == project.Id ? "selected" : null)"
                            @onclick="() => SelectProjectAsync(project)">
                        <span>@project.Name</span>
                        <small>@project.FrameworkType - @project.AnalysisCount analyses</small>
                    </button>
                }
            </section>

            <section class="analysis-panel">
                @if (selectedProject is not null)
                {
                    <div class="analysis-panel-header">
                        <div>
                            <h2>@selectedProject.Name</h2>
                            <p class="source-text" title="@selectedProject.SourceIdentifier">@CreateReadableSource(selectedProject.SourceIdentifier)</p>
                        </div>
                        <a class="secondary-link" href="@CreateGraphExplorerLink(selectedProject)">Open in Graph Explorer</a>
                    </div>
                }

                @if (isLoadingAnalyses)
                {
                    <p class="empty-state">Loading analyses...</p>
                }
                else if (!selectedAnalyses.Any())
                {
                    <div class="analysis-empty-state">
                        <p class="empty-state">No analyses saved for this project yet.</p>
                        @if (selectedProject is not null)
                        {
                            <a class="secondary-link inline" href="@CreateGraphExplorerLink(selectedProject)">Open in Graph Explorer</a>
                        }
                    </div>
                }
                else
                {
                    @if (selectedAnalysis is not null)
                    {
                        <div class="selected-analysis-summary" role="status">
                            <span>Viewing analysis</span>
                            <strong>@FormatDate(selectedAnalysis.CreatedAt)</strong>
                        </div>
                    }

                    <div class="analysis-list">
                        @foreach (var analysis in selectedAnalyses)
                        {
                            <article class="analysis-item @(selectedAnalysisId == analysis.Id ? "selected" : null)"
                                     role="button"
                                     tabindex="0"
                                     @onclick="() => ViewAnalysis(analysis)"
                                     @onkeydown="args => HandleAnalysisKeyDown(args, analysis)">
                                <div>
                                    <strong>@analysis.Summary</strong>
                                    <span>@FormatDate(analysis.CreatedAt)</span>
                                </div>
                                <dl>
                                    <div>
                                        <dt>Files</dt>
                                        <dd>@analysis.FileCount</dd>
                                    </div>
                                    <div>
                                        <dt>Nodes</dt>
                                        <dd>@analysis.NodeCount</dd>
                                    </div>
                                    <div>
                                        <dt>Edges</dt>
                                        <dd>@analysis.EdgeCount</dd>
                                    </div>
                                    <div>
                                        <dt>Endpoints</dt>
                                        <dd>@analysis.EndpointCount</dd>
                                    </div>
                                </dl>
                                <div class="analysis-actions">
                                    <button type="button"
                                            class="text-action"
                                            @onclick:stopPropagation="true"
                                            @onclick="() => ViewAnalysis(analysis)">
                                        View Analysis
                                    </button>
                                    @if (selectedProject is not null)
                                    {
                                        <a class="text-action"
                                           href="@CreateGraphExplorerLink(selectedProject)"
                                           @onclick:stopPropagation="true">
                                            Open in Graph Explorer
                                        </a>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>
    }
</section>

@code {
    private List<ProjectDto> projects = new();
    private List<ProjectAnalysisDto> selectedAnalyses = new();
    private ProjectDto? selectedProject;
    private ProjectAnalysisDto? selectedAnalysis;
    private Guid? selectedProjectId;
    private Guid? selectedAnalysisId;
    private bool isLoading = true;
    private bool isLoadingAnalyses;
    private string loadError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            projects = await GraphServiceManager.GetProjectsAsync();
            if (projects.FirstOrDefault() is { } firstProject)
            {
                await SelectProjectAsync(firstProject);
            }
        }
        catch (Exception exception)
        {
            loadError = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectProjectAsync(ProjectDto project)
    {
        selectedProject = project;
        selectedProjectId = project.Id;
        selectedAnalyses = new List<ProjectAnalysisDto>();
        selectedAnalysis = null;
        selectedAnalysisId = null;
        loadError = string.Empty;
        isLoadingAnalyses = true;

        try
        {
            selectedAnalyses = await GraphServiceManager.GetProjectAnalysesAsync(project.Id);
        }
        catch (Exception exception)
        {
            loadError = exception.Message;
        }
        finally
        {
            selectedAnalysis = selectedAnalyses.FirstOrDefault();
            selectedAnalysisId = selectedAnalysis?.Id;
            isLoadingAnalyses = false;
        }
    }

    private void ViewAnalysis(ProjectAnalysisDto analysis)
    {
        selectedAnalysis = analysis;
        selectedAnalysisId = analysis.Id;
    }

    private void HandleAnalysisKeyDown(KeyboardEventArgs args, ProjectAnalysisDto analysis)
    {
        if (args.Key is "Enter" or " ")
        {
            ViewAnalysis(analysis);
        }
    }

    private static string FormatDate(DateTime date)
    {
        return date.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private static string CreateGraphExplorerLink(ProjectDto project)
    {
        if (string.IsNullOrWhiteSpace(project.SourceIdentifier) ||
            project.SourceIdentifier.StartsWith("mock://", StringComparison.OrdinalIgnoreCase))
        {
            return "/graph";
        }

        return $"/graph?source={Uri.EscapeDataString(project.SourceIdentifier)}";
    }

    private static string CreateReadableSource(string sourceIdentifier)
    {
        if (string.IsNullOrWhiteSpace(sourceIdentifier))
        {
            return "No source path saved.";
        }

        if (sourceIdentifier.StartsWith("mock://", StringComparison.OrdinalIgnoreCase))
        {
            return "Mock graph workspace";
        }

        var trimmedSource = sourceIdentifier.Trim();

        if (trimmedSource.Length <= 68)
        {
            return trimmedSource;
        }

        var parts = trimmedSource
            .Split(['\\', '/'], StringSplitOptions.RemoveEmptyEntries)
            .ToList();

        return parts.Count >= 3
            ? $"{parts[0]}\\...\\{parts[^2]}\\{parts[^1]}"
            : $"{trimmedSource[..28]}...{trimmedSource[^28..]}";
    }
}
