@page "/settings"
@rendermode InteractiveServer

@inject AiCodeAssistant.Client.Services.UserPreferencesService UserPreferencesService

<section class="settings-page">
    <header class="page-heading">
        <div>
            <span class="page-kicker">Settings</span>
            <h1>CodeSight Settings</h1>
            <p>Local configuration for the portfolio build.</p>
        </div>
    </header>

    <div class="settings-grid">
        <section class="settings-panel">
            <h2>Graph Preferences</h2>
            <p class="settings-note">Choose the layout Graph Explorer uses when it first opens.</p>

            <label class="settings-field">
                <span>Default graph layout</span>
                <select @bind="defaultGraphLayout" disabled="@isLoadingPreference">
                    <option value="breadthfirst">Layered</option>
                    <option value="cose">Organic</option>
                </select>
            </label>

            <div class="settings-actions">
                <button type="button"
                        class="primary-button"
                        @onclick="SaveGraphPreferencesAsync"
                        disabled="@(isLoadingPreference || isSavingPreference)">
                    @(isSavingPreference ? "Saving..." : "Save preference")
                </button>
                @if (!string.IsNullOrWhiteSpace(preferenceStatus))
                {
                    <span class="settings-status @(preferenceStatusIsError ? "error" : "success")">@preferenceStatus</span>
                }
            </div>
        </section>

        <section class="settings-panel">
            <h2>Runtime</h2>
            <dl>
                <div>
                    <dt>API base URL</dt>
                    <dd>http://localhost:5217</dd>
                </div>
                <div>
                    <dt>Database provider</dt>
                    <dd>MySQL via Entity Framework Core</dd>
                </div>
                <div>
                    <dt>Connection key</dt>
                    <dd>ConnectionStrings:CodeSightDatabase</dd>
                </div>
            </dl>
        </section>

        <section class="settings-panel">
            <h2>Workspace Scope</h2>
            <dl>
                <div>
                    <dt>Authentication</dt>
                    <dd>Not enabled in Phase 2</dd>
                </div>
                <div>
                    <dt>User scope</dt>
                    <dd>Single-user local workspace</dd>
                </div>
                <div>
                    <dt>Saved analyses</dt>
                    <dd>Enabled for scanned and mock graph sessions</dd>
                </div>
            </dl>
        </section>
    </div>
</section>

@code {
    private string defaultGraphLayout = "breadthfirst";
    private bool isLoadingPreference = true;
    private bool isSavingPreference;
    private bool preferenceStatusIsError;
    private string preferenceStatus = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            defaultGraphLayout = await UserPreferencesService.GetDefaultGraphLayoutAsync();
        }
        catch (Exception exception)
        {
            preferenceStatusIsError = true;
            preferenceStatus = $"Could not load preference: {exception.Message}";
        }
        finally
        {
            isLoadingPreference = false;
        }

        StateHasChanged();
    }

    private async Task SaveGraphPreferencesAsync()
    {
        isSavingPreference = true;
        preferenceStatus = string.Empty;
        preferenceStatusIsError = false;

        try
        {
            defaultGraphLayout = AiCodeAssistant.Client.Services.UserPreferencesService.NormalizeGraphLayout(defaultGraphLayout);
            await UserPreferencesService.SaveDefaultGraphLayoutAsync(defaultGraphLayout);
            preferenceStatus = "Saved. Graph Explorer will use this layout by default.";
        }
        catch (Exception exception)
        {
            preferenceStatusIsError = true;
            preferenceStatus = $"Could not save preference: {exception.Message}";
        }
        finally
        {
            isSavingPreference = false;
        }
    }
}
