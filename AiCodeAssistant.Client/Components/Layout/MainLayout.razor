@inherits LayoutComponentBase
@inject AiCodeAssistant.Client.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="/" aria-label="CodeSight home">
            <span class="brand-mark">CS</span>
            <span class="brand-copy">
                <span class="brand-name">CodeSight</span>
                <span class="brand-tagline">Visual codebase intelligence</span>
            </span>
        </a>

        <nav class="shell-nav" aria-label="Primary navigation">
            <AuthorizeView>
                <Authorized>
            <NavLink class="shell-nav-link" href="/" Match="NavLinkMatch.All">
                <span class="shell-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M4 13h6v7H4z"></path>
                        <path d="M14 4h6v16h-6z"></path>
                        <path d="M4 4h6v5H4z"></path>
                    </svg>
                </span>
                <span class="shell-nav-label">Dashboard</span>
            </NavLink>
            <NavLink class="shell-nav-link" href="/graph">
                <span class="shell-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <circle cx="6" cy="7" r="2"></circle>
                        <circle cx="18" cy="7" r="2"></circle>
                        <circle cx="12" cy="17" r="2"></circle>
                        <path d="M8 7h8"></path>
                        <path d="M7 9l4 6"></path>
                        <path d="M17 9l-4 6"></path>
                    </svg>
                </span>
                <span class="shell-nav-label">Graph Explorer</span>
            </NavLink>
            <NavLink class="shell-nav-link" href="/history">
                <span class="shell-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M5 5h14"></path>
                        <path d="M5 12h14"></path>
                        <path d="M5 19h10"></path>
                        <path d="M3 5h.01"></path>
                        <path d="M3 12h.01"></path>
                        <path d="M3 19h.01"></path>
                    </svg>
                </span>
                <span class="shell-nav-label">Project History</span>
            </NavLink>
            <NavLink class="shell-nav-link" href="/settings">
                <span class="shell-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M12 3v3"></path>
                        <path d="M12 18v3"></path>
                        <path d="M3 12h3"></path>
                        <path d="M18 12h3"></path>
                        <path d="M5.6 5.6l2.1 2.1"></path>
                        <path d="M16.3 16.3l2.1 2.1"></path>
                    </svg>
                </span>
                <span class="shell-nav-label">Settings</span>
            </NavLink>
            <button type="button" class="shell-nav-button" @onclick="LogoutAsync">
                <span class="shell-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <path d="M16 17l5-5-5-5"></path>
                        <path d="M21 12H9"></path>
                    </svg>
                </span>
                <span class="shell-nav-label">Logout</span>
            </button>
                </Authorized>
                <NotAuthorized>
            <NavLink class="shell-nav-link" href="/login">
                <span class="shell-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                        <path d="M10 17l5-5-5-5"></path>
                        <path d="M15 12H3"></path>
                    </svg>
                </span>
                <span class="shell-nav-label">Login</span>
            </NavLink>
            <NavLink class="shell-nav-link" href="/register">
                <span class="shell-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="8.5" cy="7" r="4"></circle>
                        <path d="M20 8v6"></path>
                        <path d="M23 11h-6"></path>
                    </svg>
                </span>
                <span class="shell-nav-label">Register</span>
            </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </nav>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    <div>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
    </div>
    <button type="button" class="dismiss" aria-label="Dismiss">x</button>
</div>

@code {
    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }
}
