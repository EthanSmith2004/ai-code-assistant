@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="/" aria-label="CodeSight home">
            <span class="brand-mark">CS</span>
            <span class="brand-copy">
                <span class="brand-name">CodeSight</span>
                <span class="brand-tagline">Visual codebase intelligence</span>
            </span>
        </a>

        <nav class="shell-nav" aria-label="Primary navigation">
            <NavLink class="shell-nav-link" href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
            <NavLink class="shell-nav-link" href="/graph">Graph Explorer</NavLink>
            <NavLink class="shell-nav-link" href="/history">Project History</NavLink>
            <NavLink class="shell-nav-link" href="/settings">Settings</NavLink>
        </nav>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    <div>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
    </div>
    <button type="button" class="dismiss" aria-label="Dismiss">x</button>
</div>
